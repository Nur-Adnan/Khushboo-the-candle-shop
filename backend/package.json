{
  "name": "khusbooo-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express API for the KHUSBOOO candle discovery app.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bcrypt": "latest",
    "cloudinary": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/bcrypt": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "nodemon": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  }
}
